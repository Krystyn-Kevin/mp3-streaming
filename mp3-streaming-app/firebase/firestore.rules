rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // songs/{songId} — the shared personal library.
    // Any authenticated user may read AND add new songs — this is a shared,
    // open library ("anyone can upload, anyone can listen"), not a
    // multi-tenant catalog with per-user ownership. Uploaders can only
    // create documents attributed to their own uid, and can't edit or
    // delete songs added by someone else (prevents one user from
    // overwriting or wiping another user's uploads).
    match /songs/{songId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.artist is string
        && request.resource.data.audioUrl is string
        && request.resource.data.duration is number;
      allow update, delete: if request.auth != null
        && resource.data.uploadedBy == request.auth.uid;
    }

    // users/{uid} — profile doc, and per-user subcollections for
    // favorites, history, and playlists. A user may only read/write their
    // own data.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /favorites/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /history/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
