rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // audio/{uid}/{fileName} and covers/{uid}/{fileName} — the shared
    // library's audio files and cover art. Any signed-in user can read
    // (stream/view) anything here — that's the point, it's a shared
    // library. Writes are scoped to the uploader's own uid folder so
    // people can't overwrite each other's files, with basic size/type
    // checks so this doesn't become an open file host.
    match /audio/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    match /covers/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
