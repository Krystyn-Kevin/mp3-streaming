rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ⚠️ EDIT THIS: same address as in firestore.rules and your .env's
    // VITE_ADMIN_EMAIL. Storage rules and Firestore rules are separate
    // systems, so this has to be set in both places.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == "your-email@example.com";
    }

    // audio/{uid}/{fileName} and covers/{uid}/{fileName} — the shared
    // library's audio files and cover art.
    // Read (streaming/listening) is open to any signed-in user.
    // Write (upload/delete) is restricted to the admin account only, with
    // basic size/type checks so it doesn't become an open file host.
    match /audio/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    match /covers/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
